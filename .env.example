# Template for ~/.env — copy to ~/.env and fill in real values.
#
#   cp .env.example ~/.env && chmod 600 ~/.env
#
# ~/.env lives in $HOME (outside this repo) and is sourced by .zshrc
# (`[[ -f ~/.env ]] && source ~/.env`). Because the shell sources it,
# each line must use `export` so the variable reaches child processes.
# Never put real values in this file — only here as empty placeholders.

# OpenClaw gateway auth token.
export OPENCLAW_GATEWAY_TOKEN=
