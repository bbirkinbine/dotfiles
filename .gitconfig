[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
    name = Brian Birkinbine
	email = 585281+bbirkinbine@users.noreply.github.com
[init]
    defaultBranch = main
[pull]
    rebase = true
[rebase]
    autoStash = true
    autoSquash = true
[push]
    autoSetupRemote = true
[fetch]
    prune = true
[merge]
    conflictstyle = zdiff3
[diff]
    algorithm = histogram
[commit]
    verbose = true
[branch]
    sort = -committerdate
[alias]
    s = status -sb
    co = checkout
    br = branch
    lg = log --oneline --graph --decorate --all
[help]
    autocorrect = prompt
[core]
	excludesfile = ~/.gitignore_global
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
